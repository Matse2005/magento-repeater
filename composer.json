{
  "name": "matsevh/mage2-module-repeater",
  "description": "Add repeatable content to any widget",
  "type": "magento2-module",
  "homepage": "https://magento-repeater.matsevh.be",
  "license": "MIT",
  "authors": [
    {
      "name": "Matse Van Horebeek",
      "email": "matse.vanhorebeek@gmail.com",
      "homepage": "https://matsevh.be",
      "role": "Developer"
    }
  ],
  "autoload": {
    "files": [
      "registration.php"
    ],
    "psr-4": {
      "MatseVH\\Repeater\\": ""
    }
  },
  "require-dev": {
    "phpro/grumphp-shim": "^2.19",
    "phpstan/phpstan": "^2.1"
  },
  "config": {
    "allow-plugins": {
      "phpro/grumphp-shim": true
    }
  },
  "require": {
    "php": ">=8.3 <8.4",
    "azjezz/psl": "^4.3"
  }
}
