{
  "name": "matsevh/mage2-module-repeater",
  "description": "Add repeatable content to any widget",
  "type": "magento2-module",
  "license": [
    "MIT"
  ],
  "autoload": {
    "files": [
      "registration.php"
    ],
    "psr-4": {
      "MatseVH\\Repeater\\": ""
    }
  },
  "require-dev": {
    "phpro/grumphp-shim": "^2.19"
  },
  "config": {
    "allow-plugins": {
      "phpro/grumphp-shim": true
    }
  },
  "require": {
    "php": ">=8.4",
    "php-standard-library/php-standard-library": "^6.1"
  }
}
